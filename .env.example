# Copy this file to `.env` in the repo root for local `dotnet run`.
# Heroku: set the same keys in Settings → Config Vars (do not commit real secrets).

# Full URI from JawsDB / MySQL add-on dashboard (mysql://user:pass@host:port/dbname)
DATABASE_URL=

# Must be 32+ characters (match between deploys so existing JWTs stay valid)
Jwt__SigningKey=CHANGE_ME_TO_A_RANDOM_32_CHAR_MINIMUM_SECRET_STRING
